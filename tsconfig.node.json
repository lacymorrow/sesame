{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "src/preload/index.d.ts",
    "electron-vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/core/**/*",
    "src/cli/**/*",
    "lib/window/ipcEvents.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "bundler",
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  }
}
